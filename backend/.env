# ── Database ──
DATABASE_URL=postgresql+asyncpg://unigpu:unigpu_secret@localhost:5432/unigpu

# ── Redis (rate limiting only) ──
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ (Celery broker) ──
# Local dev: run  docker run -d -p 5672:5672 rabbitmq:3-management
# Production: set to your CloudAMQP amqps:// URL in .env.prod
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# ── JWT ──
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Billing ──
RATE_PER_SECOND=0.001

# ── Heartbeat ──
HEARTBEAT_TIMEOUT_SECONDS=60

# ── Uploads ──
UPLOAD_DIR=uploads

DEBUG=true          #see /docs for testing

# ── Google OAuth ──
GOOGLE_CLIENT_ID=657560622371-3lq2t0rthg28qbini9ou7aollackku3d.apps.googleusercontent.com
