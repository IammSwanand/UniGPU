# ─────────────────────────────────────────────────────────────────────────────
# UniGPU Backend — Production Environment Variables
# Copy this to backend/.env.prod and fill in real values.
# NEVER commit .env.prod to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase) ──
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
# Use the "Session mode" (port 5432) URL, not the Transaction mode.
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Redis (Upstash) ──
# Get from: Upstash Console → your database → .env tab
# ⚠️  Upstash requires TLS — use rediss:// (double-s) with port 6380
REDIS_URL=rediss://default:[password]@[host].upstash.io:6380/0

# ── RabbitMQ (Celery Broker — CloudAMQP) ──
# 1. Go to https://www.cloudamqp.com and create a free "Little Lemur" instance
# 2. Open the instance → copy the "AMQP URL" (starts with amqps://)
# 3. Paste it here
RABBITMQ_URL= add_here

# ── JWT ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_64_char_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Billing ──
RATE_PER_SECOND=0.002

# ── Heartbeat ──
HEARTBEAT_TIMEOUT_SECONDS=60

# ── File Storage (local fallback — overridden by OCI in production) ──
UPLOAD_DIR=/tmp/uploads

# ── Oracle Cloud Object Storage ──
# Bucket:      OCI Console → Storage → Object Storage → Create Bucket (name: unigpu-jobs, Private)
# Namespace:   shown at top of the bucket list page
# Region:      whichever region your VM is in e.g. ap-mumbai-1, us-ashburn-1
# Credentials: OCI Console → Profile (top-right) → My Profile → Customer Secret Keys → Generate
OCI_NAMESPACE=CHANGE_ME_your_tenancy_namespace
OCI_REGION=CHANGE_ME_e.g_ap-mumbai-1
OCI_BUCKET=unigpu-jobs
OCI_ACCESS_KEY=CHANGE_ME_customer_secret_key_access_key_id
OCI_SECRET_KEY=CHANGE_ME_customer_secret_key_secret

# ── CORS ──
# Frontend is on Vercel at unigpu.in, API is at api.unigpu.in
# Both origins must be allowed
ALLOWED_ORIGINS=https://unigpu.in,https://www.unigpu.in

# ── App Mode ──
DEBUG=false
