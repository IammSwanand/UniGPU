# ─────────────────────────────────────────────────────────
# UniGPU Backend — Production Environment Variables
# Copy this to .env.prod and fill in real values.
# NEVER commit .env.prod to git.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_USER=unigpu
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=unigpu
DATABASE_URL=postgresql+asyncpg://unigpu:CHANGE_ME_strong_random_password@postgres:5432/unigpu

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_random_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Billing ──
RATE_PER_SECOND=0.001

# ── Heartbeat ──
HEARTBEAT_TIMEOUT_SECONDS=60

# ── Uploads ──
UPLOAD_DIR=uploads

# ── CORS ──
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://YOUR_DOMAIN
