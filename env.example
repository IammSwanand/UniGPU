# ── UniGPU Deployment Configuration Template ──
# Copy this file to backend/.env and fill in your values
# NEVER commit actual secrets to the repository

# ── Database ──
# Local dev: sqlite+aiosqlite:///./unigpu.db
# Production: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://unigpu:your-secure-db-password-here@localhost:5432/unigpu

# ── Redis ──
# Local dev: redis://localhost:6379/0
# Production (Upstash): redis://:your-password@your-host:port
REDIS_URL=redis://localhost:6379/0

# ── JWT / Security ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=generate-a-random-secret-key-with-32-chars-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Billing ──
# Cost in credits per second of GPU usage
RATE_PER_SECOND=0.002

# ── Heartbeat ──
# Seconds before marking a GPU as offline
HEARTBEAT_TIMEOUT_SECONDS=60

# ── File Uploads ──
UPLOAD_DIR=uploads

# ── CORS & Frontend ──
# Local dev: http://localhost:5173
# Production: https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Email (Brevo SMTP) ──
# Free tier: 300 emails/day — https://www.brevo.com
# Setup: Brevo → Settings → SMTP & API → SMTP → Generate SMTP key
#   SMTP_USER = your Brevo account login email (NOT the SMTP key name)
#   SMTP_PASSWORD = the SMTP key (NOT your API key or account password)
# Leave SMTP_HOST empty in dev — reset links are logged to the backend console.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_FROM=noreply@unigpu.in
SMTP_USE_TLS=true

# ── Debug Mode ──
# Set to "false" in production
DEBUG=true

# ── Google Drive Integration (backend-only) ──
# Credentials from Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Authorized redirect URIs must include: http://localhost:5173/oauth/gdrive/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Fernet symmetric key for encrypting stored GDrive refresh tokens.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GDRIVE_ENCRYPTION_KEY=generate-a-32-byte-fernet-key

# ── Dataset Upload Limits ──
# Maximum allowed direct dataset upload size in bytes (default: 2 GB)
# MAX_DATASET_SIZE_BYTES=2147483648
